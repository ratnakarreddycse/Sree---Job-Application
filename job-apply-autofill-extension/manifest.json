{
  "manifest_version": 3,
  "name": "Job Apply Autofill Helper",
  "version": "0.2.0",
  "description": "Autofill job application forms, adaptively learn answers, and surface the correct tailored resume per job.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "clipboardWrite"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.dice.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.glassdoor.com/*",
    "https://*.builtin.com/*",
    "https://*.ashbyhq.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.stripe.com/*",
    "https://*.airbnb.com/*",
    "https://*.coinbase.com/*",
    "https://*.brex.com/*",
    "https://*.affirm.com/*",
    "https://*.databricks.com/*",
    "https://*.confluent.io/*",
    "https://*.snowflake.com/*",
    "https://*.plaid.com/*",
    "https://*.fivetran.com/*",
    "https://*.lyft.com/*",
    "https://*.robinhood.com/*",
    "https://*.getdbt.com/*",
    "https://*.block.xyz/*",
    "https://*.squareup.com/*"
  ],
  "action": {
    "default_title": "Job Autofill",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.dice.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.glassdoor.com/*",
        "https://*.builtin.com/*",
        "https://*.ashbyhq.com/*",
        "https://jobs.ashbyhq.com/*",
        "https://*.stripe.com/*",
        "https://*.airbnb.com/*",
        "https://*.coinbase.com/*",
        "https://*.brex.com/*",
        "https://*.affirm.com/*",
        "https://*.databricks.com/*",
        "https://*.confluent.io/*",
        "https://*.snowflake.com/*",
        "https://*.plaid.com/*",
        "https://*.fivetran.com/*",
        "https://*.lyft.com/*",
        "https://*.robinhood.com/*",
        "https://*.getdbt.com/*",
        "https://*.block.xyz/*",
        "https://*.squareup.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
